import os
import json
import math

# --- Load Data ---
base_path = os.path.dirname(os.path.abspath(__file__))
with open(os.path.join(base_path, "item list.json"), "r") as f:
    data = json.load(f)

def find_recipes(item_name):
    paths = []
    for m_name, m_data in data["machines"].items():
        if item_name in m_data["recipes"]:
            paths.append((m_name, m_data["recipes"][item_name]))
    return paths

def trace_ingredients(ingredients, depth=0):
    indent = "  " * depth
    for item, amount in ingredients.items():
        qty = amount['amount'] if isinstance(amount, dict) else amount
        paths = find_recipes(item)
        
        if not paths:
            print(f"{indent}- Needs {qty}x {item} [INFINITE RESOURCE]")
        else:
            print(f"{indent}- Needs {qty}x {item}")
            # Ask path if multiple, otherwise ask to drill down
            if len(paths) > 1:
                print(f"{indent}  Paths for {item}:")
                for i, (m, _) in enumerate(paths):
                    print(f"{indent}    {i+1}: {m}")
                idx = int(input(f"{indent}  Select machine (1-{len(paths)}): ")) - 1
                _, r_data = paths[idx]
            else:
                machine, r_data = paths[0]
                if input(f"{indent}  Automate {item} via {machine}? (y/n): ").lower() != 'y':
                    continue
            
            trace_ingredients(r_data["ingredients"], depth + 1)

# --- MAIN LOOP ---
while True:
    print("\n" + "="*30)
    print("   SELECT MACHINE")
    print("="*30)
    
    machines = list(data["machines"].keys())
    for i, m in enumerate(machines):
        print(f"{i+1}. {m}")
        
    m_choice = int(input("\nChoice: ")) - 1
    m_name = machines[m_choice]
    
    print("\n" + "-"*30)
    print(f"   RECIPES: {m_name.upper()}")
    print("-"*30)
    
    recipes = list(data["machines"][m_name]["recipes"].keys())
    for i, r in enumerate(recipes):
        print(f"{i+1}. {r}")
        
    r_choice = int(input("\nChoice: ")) - 1
    r_name = recipes[r_choice]
    
    recipe = data["machines"][m_name]["recipes"][r_name]
    
    # Calc
    rpm = int(input(f"\nRPM for {r_name}: "))
    goal = int(input("Items/Hr goal: "))
    
    per_sec = rpm * data["machines"][m_name]["cycle_amount_per_second"]
    needed = math.ceil((goal / 3600) / per_sec)
    
    print(f"\nResult: Need {needed}x {m_name}")
    
    if input("\nTrace to Infinite Resources? (y/n): ").lower() == 'y':
        trace_ingredients(recipe["ingredients"])
        
    if input("\nCalculate another? (y/n): ").lower() != 'y':
        break
