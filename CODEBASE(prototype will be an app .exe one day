import os
import json
import math

# --- Setup ---
base_path = os.path.dirname(os.path.abspath(__file__))
with open(os.path.join(base_path, "item list.json"), "r") as f:
    data = json.load(f)

def find_recipes(item_name):
    paths = []
    for m_name, m_data in data["machines"].items():
        if item_name in m_data["recipes"]:
            paths.append((m_name, m_data["recipes"][item_name]))
    return paths

def trace_ingredients(ingredients, depth=0):
    indent = "  " * depth
    for item, amount in ingredients.items():
        qty = amount['amount'] if isinstance(amount, dict) else amount
        paths = find_recipes(item)
        
        if not paths:
            print(f"{indent}- Needs {qty}x {item} [BASE / FARMED / MINED]")
        else:
            print(f"{indent}- Needs {qty}x {item}")
            # Ask for path selection BEFORE drilling deeper
            if len(paths) > 1:
                print(f"{indent}  Available paths for {item}:")
                for i, (m, _) in enumerate(paths):
                    print(f"{indent}    {i+1}: {m}")
                idx = int(input(f"{indent}  Select machine (1-{len(paths)}): ")) - 1
                _, r_data = paths[idx]
            else:
                machine, r_data = paths[0]
                if input(f"{indent}  Automate {item} via {machine}? (y/n): ").lower() != 'y':
                    print(f"{indent}  {item} marked as base.")
                    continue
            
            # Recurse
            trace_ingredients(r_data["ingredients"], depth + 1)

# --- Main Loop ---
while True:
    print("\n" + "="*50)
    print("MACHINES & RECIPES")
    print("="*50)
    
    machine_list = list(data["machines"].keys())
    for i, m_name in enumerate(machine_list):
        print(f"\n[{i+1}] MACHINE: {m_name}")
        print("-" * 50)
        for r_name in data["machines"][m_name]["recipes"].keys():
            print(f"    Recipe: {r_name}")
    
    m_idx = int(input("\nSelect Machine Index: ")) - 1
    m_name = machine_list[m_idx]
    
    recipe_list = list(data["machines"][m_name]["recipes"].keys())
    r_idx = int(input(f"Select Recipe Index (1-{len(recipe_list)}): ")) - 1
    r_name = recipe_list[r_idx]
    
    recipe = data["machines"][m_name]["recipes"][r_name]
    
    print(f"\n--- CALCULATING: {r_name} ---")
    rpm = int(input("Target RPM: "))
    hourly_goal = int(input("Items/Hr goal: "))
    
    items_per_sec = rpm * data["machines"][m_name]["cycle_amount_per_second"]
    machines_needed = math.ceil((hourly_goal / 3600) / items_per_sec)
    
    print(f"\nREQUIRED: {machines_needed}x {m_name}")
    
    if input("\nTrace full automation tree to base materials? (y/n): ").lower() == 'y':
        print("\n--- PRODUCTION TREE ---")
        trace_ingredients(recipe["ingredients"])
        
    if input("\nCalculate another? (y/n): ").lower() != 'y': break
