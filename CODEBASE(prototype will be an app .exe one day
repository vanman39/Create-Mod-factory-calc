import os
import json
import math

# --- Setup: Find and load the JSON ---
base_path = os.path.dirname(os.path.abspath(__file__))
json_path = os.path.join(base_path, "item list.json")

with open(json_path, "r") as f:
    data = json.load(f)

# --- Functions for Tracing ---
def find_all_recipes_for_item(item_name, data):
    paths = []
    for machine_name, m_data in data["machines"].items():
        if item_name in m_data["recipes"]:
            paths.append((machine_name, m_data["recipes"][item_name]))
    return paths

def trace_ingredients(ingredients_dict, data, depth=0):
    indent = "  " * depth
    for item, amount in ingredients_dict.items():
        # Skip fluids if they aren't part of your machine recipes
        if isinstance(item, dict) or item in ["water", "milk"]: continue
        
        paths = find_all_recipes_for_item(item, data)
        if not paths:
            print(f"{indent}- Needs {amount}x {item} (No automated recipe found)")
            continue
            
        print(f"{indent}- Needs {amount}x {item}")
        
        if len(paths) > 1:
            print(f"{indent}  Multiple ways to make {item}:")
            for i, (m_name, _) in enumerate(paths):
                print(f"{indent}    {i+1}: {m_name}")
            try:
                choice = int(input(f"{indent}  Choose a path (1-{len(paths)}): ")) - 1
                machine, r_data = paths[choice]
            except: continue
        else:
            machine, r_data = paths[0]
            choice = input(f"{indent}  Automate {item} via {machine}? (y/n): ")
            if choice.lower() != 'y': continue
            
        trace_ingredients(r_data["ingredients"], data, depth + 1)

# --- MAIN LOOP ---
while True:
    print("\nAvailable machines: " + ", ".join(data["machines"].keys()))
    machine_choice = input("Enter machine name: ")
    if machine_choice not in data["machines"]: continue
    
    recipes = data["machines"][machine_choice]["recipes"]
    print("\nRecipes: " + ", ".join(recipes.keys()))
    recipe_choice = input("Enter recipe name: ")
    if recipe_choice not in recipes: continue

    recipe = recipes[recipe_choice]
    target_rpm = int(input("Target RPM: "))
    items_wanted = int(input("Items needed per hour: ")) / 3600
    
    # Calculation
    items_produced = target_rpm * data["machines"][machine_choice]["cycle_amount_per_second"]
    machines_needed = math.ceil(items_wanted / items_produced)
    
    print(f"\nResult: {machines_needed}x {machine_choice} required.")
    print(f"Heated: {recipe['heated']}")
    
    # Byproducts
    print("\nByproducts (Expected per hour):")
    for b_item, rate in recipe["byproducts"].items():
        if b_item != "none":
            yield_hr = rate * (items_produced * machines_needed * 3600)
            print(f"- {b_item}: {yield_hr:.2f}")
        else:
            print("- None")

    # Trace Back
    if input("\nTrace back all ingredients? (y/n): ").lower() == 'y':
        trace_ingredients(recipe["ingredients"], data)
        
    if input("\nCalculate another? (y/n): ").lower() != 'y': break
