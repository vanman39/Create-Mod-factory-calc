print("This is the create calc.")
import os
import json
import math
while 1 + 1 == 2:
    base_path = os.path.dirname(os.path.abspath(__file__))
    with open(os.path.join(base_path, "item list.json"), "r") as f:
        data = json.load(f)
    print("Available machines: ")
    for machine_name in data["machines"].keys():
        print(f"- {machine_name}")
    machine_choice = input("Enter the machine name from the list above: ")
    for recipe_name in data["machines"][machine_choice]["recipes"].keys():
        product_name = data["machines"][machine_choice]["recipes"][recipe_name]["products"]
        print(f"- {product_name}")
    recipe_choice = input("Enter the recipe name from the list above: ")
    target_rpm = int(input("Enter the target RPM: "))
    items_wanted = int(input("Enter the number of items you want to produce per hour: "))
    items_wanted = items_wanted / 3600
    answer = data["machines"][machine_choice]["recipes"][recipe_choice]
    items_produced = target_rpm * data["machines"][machine_choice]["cycle_amount_per_second"]
    machines_needed = math.ceil(items_wanted / items_produced)
    print(f"You will need {machines_needed} {machine_choice} machines to produce {items_wanted * 3600} items per hour at {target_rpm} RPM.")
    print("Make sure you have automated: ")
    heated = data["machines"][machine_choice]["recipes"][recipe_choice]["heated"]
    print(f"- Heated: {heated}")
    print("Ingredients: ")
    for ingredient in data["machines"][machine_choice]["recipes"][recipe_choice]["ingredients"].keys():
        print(f"- {ingredient}: {data['machines'][machine_choice]['recipes'][recipe_choice]['ingredients'][ingredient]}")
    print("\n")
